{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@baby-food/shared-types": ["packages/shared-types/src/index.ts"],
      "@baby-food/ui-tokens": ["packages/ui-tokens/src/index.ts"]
    }
  }
}