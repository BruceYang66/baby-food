{
  "name": "baby-food-generator",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:miniapp": "npm run dev --workspace @baby-food/miniapp",
    "dev:admin": "npm run dev --workspace @baby-food/admin-web",
    "dev:api": "npm run dev --workspace @baby-food/api",
    "build:miniapp": "npm run build --workspace @baby-food/miniapp",
    "build:admin": "npm run build --workspace @baby-food/admin-web",
    "build:api": "npm run build --workspace @baby-food/api"
  }
}