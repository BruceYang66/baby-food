# API 服务监听端口，本地默认 3000
PORT=3000

# 运行环境，开发时通常用 development
NODE_ENV=development

# 微信小程序 AppID：对应你的小程序唯一标识
WECHAT_APP_ID=appid测试

# 微信小程序 AppSecret：仅后端保存，用于调用微信 jscode2session 换取 openid/session_key
# 注意：不要提交真实密钥到仓库
WECHAT_SECRET=123123123ceso

# JWT 签名密钥：后端用它来签发/校验登录 token
# 它不是微信密钥，可以自行生成一串足够长的随机字符串
JWT_SECRET=replace-with-a-long-random-jwt-secret

# PostgreSQL 连接串：API 通过它连接数据库
DATABASE_URL=postgresql://postgres:23423@122234:5432/baby_food
