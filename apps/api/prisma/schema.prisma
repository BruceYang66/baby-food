generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  draft
  pending_review
  published
  offline
  trash

  @@map("content_status")
}

enum ReviewStatus {
  none
  pending
  approved
  rejected

  @@map("review_status")
}

enum BabyMemberRole {
  owner
  collaborator
  caregiver
  viewer

  @@map("baby_member_role")
}

enum BabyInviteStatus {
  pending
  accepted
  declined
  revoked
  expired

  @@map("baby_invite_status")
}

enum FeedingRecordStatus {
  fed
  skipped

  @@map("feeding_record_status")
}

enum VaccineCategory {
  free
  optional

  @@map("vaccine_category")
}

enum VaccineRecordStatus {
  pending
  completed
  optional

  @@map("vaccine_record_status")
}

enum KnowledgeContentType {
  article
  guide
  taboo

  @@map("knowledge_content_type")
}

model User {
  id                String                  @id @default(cuid())
  nickname          String
  avatarUrl         String?                 @map("avatar_url")
  wechatOpenId      String?                 @unique @map("wechat_open_id")
  activityLabel     String?                 @map("activity_label")
  statusLabel       String?                 @map("status_label")
  canAppAdmin       Boolean                 @default(false) @map("can_app_admin")
  activeBabyId      String?                 @map("active_baby_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  babies            Baby[]
  ownedBabyInvites  BabyInvite[]            @relation("BabyInviteCreator")
  babyMembers       BabyMember[]
  receivedInvites   BabyInvite[]            @relation("BabyInviteRecipient")
  favorites         UserFavorite[]
  knowledgeFavorites UserKnowledgeFavorite[]

  @@map("users")
}

model Baby {
  id                 String          @id @default(cuid())
  userId             String          @map("user_id")
  nickname           String
  birthDate          DateTime        @map("birth_date")
  stageLabel         String          @map("stage_label")
  avatarUrl          String?         @map("avatar_url")
  backgroundImageUrl String?         @map("background_image_url")
  relationshipLabel  String?         @map("relationship_label")
  gender             String?
  allergens          BabyAllergen[]
  mealPlans          MealPlan[]
  customRecipes      CustomRecipe[]
  vaccineRecords     VaccineRecord[]
  members            BabyMember[]
  invites            BabyInvite[]
  user               User            @relation(fields: [userId], references: [id])

  @@map("babies")
}

model BabyMember {
  id          String         @id @default(cuid())
  babyId      String         @map("baby_id")
  userId      String         @map("user_id")
  role        BabyMemberRole @default(collaborator)
  displayName String?        @map("display_name")
  createdAt   DateTime       @default(now()) @map("created_at")
  baby        Baby           @relation(fields: [babyId], references: [id])
  user        User           @relation(fields: [userId], references: [id])

  @@unique([babyId, userId])
  @@map("baby_members")
}

model BabyInvite {
  id                String           @id @default(cuid())
  babyId            String           @map("baby_id")
  inviterUserId     String           @map("inviter_user_id")
  inviteeUserId     String?          @map("invitee_user_id")
  inviteeNickname   String?          @map("invitee_nickname")
  inviteeContact    String?          @map("invitee_contact")
  role              BabyMemberRole   @default(collaborator)
  status            BabyInviteStatus @default(pending)
  inviteCode        String           @unique @map("invite_code")
  expiresAt         DateTime?        @map("expires_at")
  respondedAt       DateTime?        @map("responded_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  baby              Baby             @relation(fields: [babyId], references: [id])
  inviterUser       User             @relation("BabyInviteCreator", fields: [inviterUserId], references: [id])
  inviteeUser       User?            @relation("BabyInviteRecipient", fields: [inviteeUserId], references: [id])

  @@index([inviteeUserId, status])
  @@index([babyId, status])
  @@map("baby_invites")
}

model BabyAllergen {
  id       String @id @default(cuid())
  babyId   String @map("baby_id")
  name     String
  severity String?
  baby     Baby   @relation(fields: [babyId], references: [id])

  @@map("baby_allergens")
}

model Recipe {
  id              String         @id @default(cuid())
  title           String
  summary         String?
  coverImage      String?        @map("cover_image")
  ageLabel        String         @map("age_label")
  ageMinMonths    Int            @map("age_min_months")
  ageMaxMonths    Int?           @map("age_max_months")
  durationLabel   String         @map("duration_label")
  difficultyLabel String         @map("difficulty_label")
  source          String?
  creator         String?
  favorites       Int            @default(0)
  reviewFocus     String?        @map("review_focus")
  contentStatus   ContentStatus  @default(draft) @map("content_status")
  reviewStatus    ReviewStatus   @default(none) @map("review_status")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  ingredients     RecipeIngredient[]
  steps           RecipeStep[]
  tags            RecipeTag[]
  versions        RecipeVersion[]
  reviews         RecipeReview[]
  mealPlanItems   MealPlanItem[]
  userFavorites   UserFavorite[]

  @@index([contentStatus, ageMinMonths, ageMaxMonths])
  @@map("recipes")
}

model CustomRecipe {
  id            String         @id @default(cuid())
  babyId        String         @map("baby_id")
  title         String
  focus         String?
  coverImage    String?        @map("cover_image")
  tagsJson      String         @default("[]") @map("tags_json")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  baby          Baby           @relation(fields: [babyId], references: [id])
  mealPlanItems MealPlanItem[]

  @@map("custom_recipes")
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String @map("recipe_id")
  name     String
  amount   String
  unit     String?
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  @@map("recipe_ingredients")
}

model RecipeStep {
  id          String @id @default(cuid())
  recipeId    String @map("recipe_id")
  stepNo      Int    @map("step_no")
  title       String
  description String
  imageUrl    String? @map("image_url")
  recipe      Recipe @relation(fields: [recipeId], references: [id])

  @@map("recipe_steps")
}

model RecipeTag {
  id       String @id @default(cuid())
  recipeId String @map("recipe_id")
  name     String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  @@map("recipe_tags")
}

model MealPlan {
  id              String          @id @default(cuid())
  babyId          String          @map("baby_id")
  title           String
  planDate        DateTime        @map("plan_date") @db.Date
  dateLabel       String          @map("date_label")
  nutritionScore  Int             @map("nutrition_score")
  waterSuggestion String?         @map("water_suggestion")
  baby            Baby            @relation(fields: [babyId], references: [id])
  items           MealPlanItem[]
  feedingRecords  FeedingRecord[]

  @@unique([babyId, planDate])
  @@map("meal_plans")
}

model MealPlanItem {
  id                String          @id @default(cuid())
  mealPlanId        String          @map("meal_plan_id")
  recipeId          String?         @map("recipe_id")
  customRecipeId    String?         @map("custom_recipe_id")
  slot              String
  time              String
  title             String
  focus             String?
  snapshotTitle     String?         @map("snapshot_title")
  snapshotFocus     String?         @map("snapshot_focus")
  snapshotImage     String?         @map("snapshot_image")
  snapshotTagsJson  String?         @map("snapshot_tags_json")
  mealPlan          MealPlan        @relation(fields: [mealPlanId], references: [id])
  recipe            Recipe?         @relation(fields: [recipeId], references: [id])
  customRecipe      CustomRecipe?   @relation(fields: [customRecipeId], references: [id])
  feedingRecords    FeedingRecord[]

  @@map("meal_plan_items")
}

model FeedingRecord {
  id             String              @id @default(cuid())
  mealPlanId     String              @map("meal_plan_id")
  mealPlanItemId String              @map("meal_plan_item_id")
  status         FeedingRecordStatus
  note           String?
  fedAt          DateTime?           @map("fed_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  mealPlan       MealPlan            @relation(fields: [mealPlanId], references: [id])
  mealPlanItem   MealPlanItem        @relation(fields: [mealPlanItemId], references: [id])

  @@unique([mealPlanItemId])
  @@index([mealPlanId])
  @@map("feeding_records")
}

model GuideStage {
  id                String          @id @default(cuid())
  key               String          @unique
  label             String
  title             String
  description       String
  feedingTipsJson   String          @default("[]") @map("feeding_tips_json")
  qaJson            String          @default("[]") @map("qa_json")
  dailyScheduleJson String          @default("[]") @map("daily_schedule_json")
  sortOrder         Int             @default(0) @map("sort_order")
  rules             GuideFoodRule[]

  @@map("guide_stages")
}

model GuideFoodRule {
  id         String     @id @default(cuid())
  stageId    String     @map("stage_id")
  type       String
  title      String
  foodsJson  String     @map("foods_json")
  guideStage GuideStage @relation(fields: [stageId], references: [id])

  @@map("guide_food_rules")
}

model SymptomGuide {
  id          String             @id @default(cuid())
  symptom     String             @unique
  title       String
  rules       SymptomFoodRule[]

  @@map("symptom_guides")
}

model SymptomFoodRule {
  id             String       @id @default(cuid())
  symptomGuideId String       @map("symptom_guide_id")
  type           String
  food           String
  reason         String
  symptomGuide   SymptomGuide @relation(fields: [symptomGuideId], references: [id])

  @@map("symptom_food_rules")
}

model RecipeReview {
  id         String       @id @default(cuid())
  recipeId   String       @map("recipe_id")
  action     ReviewStatus
  comment    String?
  createdAt  DateTime     @default(now()) @map("created_at")
  recipe     Recipe       @relation(fields: [recipeId], references: [id])

  @@map("recipe_reviews")
}

model RecipeVersion {
  id          String   @id @default(cuid())
  recipeId    String   @map("recipe_id")
  versionNo   Int      @map("version_no")
  snapshot    String
  createdAt   DateTime @default(now()) @map("created_at")
  recipe      Recipe   @relation(fields: [recipeId], references: [id])

  @@map("recipe_versions")
}

model ImportJob {
  id         String   @id @default(cuid())
  fileName   String   @map("file_name")
  operator   String
  total      Int
  success    Int
  failed     Int
  status     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("import_jobs")
}

model SystemSetting {
  id         String   @id @default(cuid())
  settingKey String   @unique @map("setting_key")
  settingVal String   @map("setting_val")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  recipeId  String   @map("recipe_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
  recipe    Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([userId, recipeId])
  @@map("user_favorites")
}

model VaccineSchedule {
  id                  String           @id @default(cuid())
  name                String
  disease             String
  stageLabel          String           @map("stage_label")
  recommendedAgeLabel String           @map("recommended_age_label")
  category            VaccineCategory
  description         String?
  precautionsJson     String           @default("[]") @map("precautions_json")
  sortOrder           Int              @default(0) @map("sort_order")
  records             VaccineRecord[]

  @@map("vaccine_schedules")
}

model VaccineRecord {
  id           String              @id @default(cuid())
  babyId        String              @map("baby_id")
  scheduleId    String              @map("schedule_id")
  status        VaccineRecordStatus @default(pending)
  vaccinatedAt  DateTime?           @map("vaccinated_at") @db.Date
  note          String?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  baby          Baby                @relation(fields: [babyId], references: [id])
  schedule      VaccineSchedule     @relation(fields: [scheduleId], references: [id])

  @@unique([babyId, scheduleId])
  @@index([babyId, status])
  @@map("vaccine_records")
}

model KnowledgeArticle {
  id            String               @id @default(cuid())
  title         String
  subtitle      String
  summary       String
  coverImage    String?              @map("cover_image")
  categoryKey   String               @map("category_key")
  categoryLabel String               @map("category_label")
  tagsJson      String               @default("[]") @map("tags_json")
  contentType   KnowledgeContentType @map("content_type")
  content       String
  isFeatured    Boolean              @default(false) @map("is_featured")
  contentStatus ContentStatus        @default(published) @map("content_status")
  sortOrder     Int                  @default(0) @map("sort_order")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  sections      KnowledgeArticleSection[]
  favorites     UserKnowledgeFavorite[]

  @@map("knowledge_articles")
}

model KnowledgeArticleSection {
  id         String           @id @default(cuid())
  articleId  String           @map("article_id")
  title      String?
  content    String
  imagesJson String           @default("[]") @map("images_json")
  sortOrder  Int              @default(0) @map("sort_order")
  article    KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("knowledge_article_sections")
}

model UserKnowledgeFavorite {
  id         String           @id @default(cuid())
  userId      String           @map("user_id")
  articleId   String           @map("article_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  user        User             @relation(fields: [userId], references: [id])
  article     KnowledgeArticle @relation(fields: [articleId], references: [id])

  @@unique([userId, articleId])
  @@map("user_knowledge_favorites")
}

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_feedback")
}

model UserLoginLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  nickname  String
  avatarUrl String?  @map("avatar_url")
  loginAt   DateTime @default(now()) @map("login_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  @@index([userId, loginAt])
  @@map("user_login_logs")
}
